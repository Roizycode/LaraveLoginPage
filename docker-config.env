# Docker Repository Configuration
# Update these values with your actual information

# Your GitHub username (replace with your actual username)
GITHUB_USERNAME=YOUR_GITHUB_USERNAME

# Your GitHub repository name (usually the same as your project folder name)
REPO_NAME=laravel-login-app

# Full Docker repository path
DOCKER_REPO=ghcr.io/YOUR_GITHUB_USERNAME/laravel-login-app

# Render service configuration
RENDER_SERVICE_NAME=laravel-login-app
RENDER_URL=https://laravel-login-app.onrender.com

# Instructions:
# 1. Replace YOUR_GITHUB_USERNAME with your actual GitHub username
# 2. Update REPO_NAME if your repository has a different name
# 3. The DOCKER_REPO will be automatically updated based on the above values
# 4. Use these values in your render-docker.yaml file
